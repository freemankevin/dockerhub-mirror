{
  "version": 2,
  "public": true,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/images.json",
      "destination": "/images.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/images.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=0, stale-while-revalidate=0"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
