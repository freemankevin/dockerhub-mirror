{
  "name": "registry-sync",
  "version": "1.0.0",
  "description": "多镜像仓库同步服务 - 纯前端展示",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./css/tailwind.src.css -o ./css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./css/tailwind.src.css -o ./css/tailwind.css --watch",
    "build": "npm run build:css",
    "dev": "npm run build:css && npx serve . -p 7886",
    "start": "npm run dev",
    "preview": "npx serve . -p 7886"
  },
  "keywords": [
    "docker",
    "mirror",
    "ghcr",
    "container-registry"
  ],
  "author": "freemankevin",
  "license": "MIT",
  "devDependencies": {
    "serve": "^14.2.0",
    "tailwindcss": "^3.4.19"
  }
}
